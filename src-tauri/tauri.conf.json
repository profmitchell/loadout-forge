{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LoadoutForge",
  "version": "0.1.0",
  "identifier": "com.cohenconcepts.loadoutforge",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run sync:resources && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LoadoutForge",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Mix and match Cohen Concepts Crimson Desert mesh mods into CDUMM loadouts.",
    "longDescription": "LoadoutForge lets you combine helm, lantern, bow, sword, and cannon replacers into a single mesh_loose_mod zip for CDUMM.",
    "resources": [
      "resources/scripts/*"
    ]
  }
}
